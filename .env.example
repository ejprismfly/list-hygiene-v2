NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Legacy Supabase projects may still use an anon key.
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-side Supabase access. Required for admin writes and production parity.
SUPABASE_SERVICE_ROLE_KEY=

# Optional direct Postgres fallback for organization/workspace APIs.
# Use the same database as NEXT_PUBLIC_SUPABASE_URL when testing against live.
DATABASE_URL=

# Public app URL for OAuth and billing return URLs.
# For side-by-side testing, use the v2 hostname, not the v1 hostname.
NEXT_PUBLIC_APP_HOST=

# Workspace mode defaults to enabled when unset. Set both explicitly in deploy envs.
NEXT_PUBLIC_ORG_WORKSPACES_ENABLED=true
ORG_WORKSPACES_ENABLED=true

# Klaviyo OAuth. The app must allow NEXT_PUBLIC_APP_HOST/api/oauth/klaviyo/callback.
NEXT_PUBLIC_KLAVIYO_CLIENT_ID=
KLAVIYO_CLIENT_SECRET=

# Stripe billing. Webhooks are still handled by the current v1/live app unless
# a v2 webhook route is intentionally added and tested.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
